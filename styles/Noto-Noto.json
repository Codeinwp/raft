{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "title": "Noto Noto",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "raft-bg",
          "color": "#F6E7CD",
          "name": "Background"
        },
        {
          "slug": "raft-fg",
          "color": "#322E27",
          "name": "Text"
        },
        {
          "slug": "raft-accent",
          "color": "#23221F",
          "name": "Accent"
        },
        {
          "slug": "raft-accent-secondary",
          "color": "#2A2926",
          "name": "Accent Secondary"
        },
        {
          "slug": "raft-bg-inv",
          "color": "#23221F",
          "name": "Dark Background"
        },
        {
          "slug": "raft-bg-alt",
          "color": "#FDF0DB",
          "name": "Light Background"
        },
        {
          "slug": "raft-fg-alt",
          "color": "#FFFFFF",
          "name": "Inverted Text"
        }
      ]
    }
  },
  "styles": {
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--noto-serif)",
			"fontWeight": "700"
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--noto-serif)",
      "fontWeight": "400"
    }
  }
}
